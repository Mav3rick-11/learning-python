# Numerical Lists
for value in range(1,6):
    print(value)

numbers = list(range(1,6))
print(numbers)

# List of even numbers from 1 to 10
even_numbers = list(range(2,11,2))
print(even_numbers)

# List of Squares from 1 to 10
squares = []
for value in range(1,11):
    squares.append(value ** 2)

print(squares)

squares = [value ** 2 for value in range(1,11)]
print(squares)

# List of numbers from 1 to 20
for value in range(1,21):
    print(value)

# List of numbers from 1 to 1 million
million = list(range(1,1000001))
print(million)
print(min(million))
print(max(million))
print(sum(million))

# List of odd numbers from 1 to 20
odd_numbers = list(range(1,20,2))
print(odd_numbers)

# List of multiples of 3 from 3 to 30
threes = list(range(3,31,3))
print(threes)

# List of cubes from 1 to 10
cubes = [value ** 3 for value in range(1,11)]
print(cubes)
